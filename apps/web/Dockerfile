# ─── Stage 1: Prune monorepo to only what gym-app needs ───────────────────────
FROM oven/bun:1.3.9-alpine AS pruner
WORKDIR /app

RUN bun add -g turbo@^2

COPY . .
RUN turbo prune gym-app --docker

# ─── Stage 2: Install pruned dependencies ─────────────────────────────────────
FROM oven/bun:1.3.9-alpine AS installer
WORKDIR /app

# Copy pruned package manifests and lockfile (generated by turbo prune --docker)
COPY --from=pruner /app/out/json/ .
COPY --from=pruner /app/out/bun.lock ./bun.lock

RUN bun install --frozen-lockfile

# ─── Stage 3: Build ───────────────────────────────────────────────────────────
FROM oven/bun:1.3.9-alpine AS builder
WORKDIR /app

COPY --from=installer /app/node_modules ./node_modules
COPY --from=pruner /app/out/full/ .

# Build-time env vars (injected by Dokploy / docker build --build-arg)
ARG VITE_CONVEX_URL
ENV VITE_CONVEX_URL=${VITE_CONVEX_URL}

ARG VITE_CONVEX_SITE_URL
ENV VITE_CONVEX_SITE_URL=${VITE_CONVEX_SITE_URL}

RUN bun turbo run build --filter=gym-app

# ─── Stage 4: Production runner ───────────────────────────────────────────────
FROM oven/bun:1.3.9-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3000

# VITE_CONVEX_SITE_URL is also checked at SSR runtime by @convex-dev/better-auth
ARG VITE_CONVEX_SITE_URL
ENV VITE_CONVEX_SITE_URL=${VITE_CONVEX_SITE_URL}

# Nitro "bun" preset emits a self-contained .output directory
COPY --from=builder /app/apps/web/.output ./.output

EXPOSE 3000

CMD ["bun", ".output/server/index.mjs"]